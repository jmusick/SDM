---
import { Icon } from "astro-icon/components";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="stylesheet" href="/universal.css" />
		<title>Contact | Stone Dragon Media</title>
		<style>
			.page { max-width:1280px; margin:0 auto; padding:2rem clamp(1.1rem,2.5vw,2.4rem) 4rem; }
			.contact-hero {
				margin-top: .4rem;
				position: relative;
				display: grid;
				grid-template-columns: .9fr 1.1fr;
				gap: 1rem;
				padding: clamp(1rem, 3vw, 2rem);
				border-radius: 1rem;
				overflow: hidden;
				border: 1px solid rgba(255,255,255,.2);
				background:
					linear-gradient(120deg, rgba(12, 27, 43, .58), rgba(20, 45, 69, .2)),
					url('/contact-bg.png') center center / cover no-repeat;
				min-height: clamp(480px, 58vw, 700px);
			}
			.contact-hero > * { position: relative; z-index: 1; }
			.intro h1 {
				margin: 0;
				font-family: "Sora",sans-serif;
				font-size: clamp(1.35rem, 2.3vw, 2rem);
				line-height: 1.05;
				color: #f2f8ff;
				max-width: 20ch;
			}
			.intro p {
				margin: .6rem 0 0;
				max-width: 42ch;
				color: rgba(229,241,255,.92);
				line-height: 1.6;
			}
			.kicker {
				display: inline-flex;
				gap: .45rem;
				align-items: center;
				font-size: .8rem;
				text-transform: uppercase;
				letter-spacing: .08em;
				font-weight: 600;
				color: #d7ebff;
				margin-bottom: .9rem;
			}
			.kicker::before {
				content: "";
				display: block;
				width: 1.6rem;
				height: 1px;
				background: rgba(193, 224, 248, .85);
			}
			.form-card {
				align-self: start;
				border: 1px solid rgba(183, 216, 241, .42);
				background: rgba(240, 247, 253, .93);
				border-radius: .95rem;
				padding: 1rem;
				backdrop-filter: blur(4px);
				max-width: 560px;
			}
			.form-card h2 {
				margin: 0 0 .35rem;
				font-family: "Sora",sans-serif;
				font-size: 1.12rem;
				color: var(--brand-strong);
			}
			.form-card p {
				margin: 0 0 .75rem;
				color: var(--ink-soft);
				font-size: .95rem;
			}
			.form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .7rem; }
			.field { display: flex; flex-direction: column; gap: .25rem; }
			.field.full { grid-column: 1 / -1; }
			label { font-size: .83rem; font-weight: 600; color: var(--brand-strong); }
			input,
			select,
			textarea {
				width: 100%;
				border: 1px solid rgba(108, 153, 188, .38);
				background: rgba(255,255,255,.95);
				border-radius: .62rem;
				padding: .62rem .7rem;
				font: inherit;
				color: var(--ink);
			}
			textarea { min-height: 120px; resize: vertical; }
			.submit-row {
				margin-top: .8rem;
				display: flex;
				justify-content: space-between;
				align-items: center;
				gap: .7rem;
			}
			.form-status {
				margin-top: .75rem;
				padding: .6rem .7rem;
				border-radius: .62rem;
				font-size: .9rem;
			}
			.form-status.success {
				background: rgba(12, 117, 58, .12);
				border: 1px solid rgba(12, 117, 58, .28);
				color: #0b5f33;
			}
			.form-status.error {
				background: rgba(173, 38, 38, .12);
				border: 1px solid rgba(173, 38, 38, .28);
				color: #7d2121;
			}
			.hcaptcha-wrap {
				margin-top: .65rem;
			}
			.helper {
				margin: 0;
				font-size: .82rem;
				color: var(--ink-soft);
			}
			.button {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				padding: 0.68rem 1rem;
				border-radius: 0.75rem;
				border: 1px solid transparent;
				font-weight: 600;
				font-family: "Sora", sans-serif;
				text-decoration: none;
				cursor: pointer;
			}
			.button .icon { width: 1rem; height: 1rem; margin-right: .35rem; }
			.button-primary { background: linear-gradient(125deg,#1f5a89,#2f709f); color:#edf6ff; }
			.intro {
				justify-self: end;
				align-self: start;
				text-align: left;
				padding-top: .35rem;
			}
			.site-footer { margin-top: 1.6rem; }
			@media (max-width:920px){
				.contact-hero { grid-template-columns: 1fr; min-height: auto; }
				.form-card { align-self: stretch; }
				.intro { justify-self: start; }
				.form-grid { grid-template-columns: 1fr; }
				.submit-row { flex-direction: column; align-items: flex-start; }
			}
		</style>
	</head>
	<body>
		<SiteHeader active="contact" />
		<div class="page">
			<section class="contact-hero" aria-label="Contact form section">
				<div class="form-card">
					<h2>Start a Conversation</h2>
					<p>Share a few project details and we will follow up quickly.</p>
					<form id="contact-form" method="post" action="https://api.web3forms.com/submit" novalidate>
						<input type="hidden" name="access_key" value="8b9f961f-4a2f-43bc-938a-11f26885cd31" />
						<div class="form-grid">
							<div class="field">
								<label for="name">Name</label>
								<input id="name" name="name" type="text" required />
							</div>
							<div class="field">
								<label for="email">Email</label>
								<input id="email" name="email" type="email" required />
							</div>
							<div class="field">
								<label for="company">Company</label>
								<input id="company" name="company" type="text" />
							</div>
							<div class="field">
								<label for="timeline">Timeline</label>
								<select id="timeline" name="timeline">
									<option>As soon as possible</option>
									<option>Within 30 days</option>
									<option>1-3 months</option>
									<option>Exploring options</option>
								</select>
							</div>
							<div class="field full">
								<label for="message">Project Details</label>
								<textarea id="message" name="message" placeholder="Tell us about your goals, scope, and desired outcomes." required></textarea>
							</div>
						</div>
						<div class="hcaptcha-wrap">
							<div class="h-captcha" data-sitekey="50b2fe65-b00b-4b9e-ad62-3ba471098be2"></div>
						</div>
						<div class="submit-row">
							<p class="helper">Share your details and we will follow up to discuss your project.</p>
							<button id="contact-submit" class="button button-primary" type="submit">
								<Icon class="icon" name="lucide:send" aria-hidden="true" />
								Send Inquiry
							</button>
						</div>
						<div id="contact-form-status" class="form-status" role="status" aria-live="polite" hidden></div>
					</form>
				</div>

				<div class="intro">
					<div class="kicker">Sandusky, Ohio</div>
					<h1>Tell us about your project.</h1>
					<p>Share the details of your project and we will reach out to discuss your needs seriously, then guide you through the process step by step.</p>
				</div>
			</section>
			<SiteFooter />
		</div>
		<script src="https://js.hcaptcha.com/1/api.js" async defer></script>
		<script>
			const form = document.getElementById("contact-form") as HTMLFormElement | null;
			const submitButton = document.getElementById("contact-submit") as HTMLButtonElement | null;
			const statusMessage = document.getElementById("contact-form-status") as HTMLDivElement | null;
			const originalButtonHtml = submitButton?.innerHTML;

			const setStatus = (type: "success" | "error", message: string) => {
				if (!statusMessage) return;
				statusMessage.hidden = false;
				statusMessage.className = `form-status ${type}`;
				statusMessage.textContent = message;
			};

			if (!form || !submitButton || !statusMessage) {
				throw new Error("Contact form elements are missing.");
			}

			form.addEventListener("submit", async (event) => {
				event.preventDefault();
				submitButton.disabled = true;
				submitButton.textContent = "Sending...";
				statusMessage.hidden = true;

				try {
					const hcaptcha = (window as Window & { hcaptcha?: { getResponse: () => string; reset: () => void } }).hcaptcha;
					const captchaResponse = hcaptcha?.getResponse();
					if (!captchaResponse) {
						setStatus("error", "Please complete the CAPTCHA.");
						return;
					}

					const formData = new FormData(form);
					const payload = {
						access_key: formData.get("access_key"),
						name: formData.get("name"),
						email: formData.get("email"),
						company: formData.get("company"),
						timeline: formData.get("timeline"),
						message: formData.get("message"),
						"h-captcha-response": captchaResponse,
					};

					const response = await fetch("https://api.web3forms.com/submit", {
						method: "POST",
						headers: { "Content-Type": "application/json" },
						body: JSON.stringify(payload),
					});

					if (!response.ok) {
						throw new Error(`HTTP ${response.status}`);
					}

					const result = await response.json();
					if (result.success) {
						setStatus("success", "Message sent successfully. We will get back to you soon.");
						form.reset();
						hcaptcha?.reset();
					} else {
						setStatus("error", result.message || "Failed to send message. Please try again.");
					}
				} catch (error: unknown) {
					const message = error instanceof Error ? error.message : "Unknown error";
					setStatus("error", `Error sending message: ${message}`);
				} finally {
					submitButton.disabled = false;
					submitButton.innerHTML = originalButtonHtml ?? "Send Inquiry";
				}
			});
		</script>
	</body>
</html>
