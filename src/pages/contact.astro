---
import { Icon } from "astro-icon/components";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact | Stone Dragon Media"
  description="Get in touch with Stone Dragon Media. Start a web project, ask about services, or discuss how we can help grow your digital presence."
  canonical="https://stonedragonmedia.com/contact/"
  ogUrl="https://stonedragonmedia.com/contact/"
>
  <Fragment slot="head">
    <style>
      .page {
        max-width: 1280px;
        margin: 0 auto;
        padding: 1rem clamp(1.1rem, 2.5vw, 2.4rem) 4rem;
      }

      .header-hero {
        position: relative;
        width: 100vw;
        left: 50%;
        right: 50%;
        margin-left: -50vw;
        margin-right: -50vw;
        height: 520px;
        max-width: 100vw;
        border-radius: 0;
        overflow: hidden;
        box-shadow: none;
        margin-bottom: 1rem;
        background: #122238;
      }

      .header-hero img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        object-position: center 70%;
      }

      .header-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
        padding: 3.5rem 3.5rem 3.5rem 8vw;
        color: #fff;
        background: linear-gradient(90deg, rgba(18, 34, 56, 0.82) 0%, rgba(18, 34, 56, 0.32) 60%, rgba(18, 34, 56, 0) 100%);
        font-family: "Sora", sans-serif;
        pointer-events: none;
        box-sizing: border-box;
      }

      .header-overlay .about-label {
        font-size: 1.1rem;
        font-weight: 600;
        letter-spacing: 0.13em;
        margin-bottom: 0.7rem;
        opacity: 0.92;
        border-bottom: 3px solid #7fa6d9;
        display: inline-block;
        padding-bottom: 0.2rem;
      }

      .header-overlay .hero-title {
        font-size: 2.8rem;
        font-weight: 800;
        margin-bottom: 1.2rem;
        line-height: 1.1;
        text-shadow: 0 2px 16px rgba(0, 0, 0, 0.18);
      }

      .header-overlay .hero-desc {
        font-size: 1.25rem;
        font-weight: 400;
        max-width: 32rem;
        line-height: 1.5;
        text-shadow: 0 2px 16px rgba(0, 0, 0, 0.18);
      }

      .contact-layout {
        display: grid;
        grid-template-columns: 1fr 320px;
        gap: 1.5rem;
        align-items: start;
      }

      .form-card {
        align-self: start;
        border: 1px solid var(--line);
        background: var(--surface);
        border-radius: 0.95rem;
        padding: 1rem;
      }

      .info-panel {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }

      .info-item {
        display: flex;
        gap: 0.85rem;
        align-items: flex-start;
        border: 1px solid var(--line);
        background: var(--surface);
        border-radius: 0.95rem;
        padding: 1rem;
      }

      .info-icon {
        width: 1.1rem;
        height: 1.1rem;
        color: var(--brand-strong);
        flex-shrink: 0;
        margin-top: 0.15rem;
      }

      .info-item h3 {
        margin: 0 0 0.3rem;
        font-family: "Sora", sans-serif;
        font-size: 1rem;
        color: var(--brand-strong);
      }

      .info-item p {
        margin: 0;
        color: var(--ink-soft);
        font-size: 0.92rem;
        line-height: 1.5;
      }

      .form-card h2 {
        margin: 0 0 0.35rem;
        font-family: "Sora", sans-serif;
        font-size: 1.12rem;
        color: var(--brand-strong);
      }

      .form-card p {
        margin: 0 0 0.75rem;
        color: var(--ink-soft);
        font-size: 0.95rem;
      }

      .form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.7rem;
      }

      .field {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
      }

      .field.full {
        grid-column: 1 / -1;
      }

      label {
        font-size: 0.83rem;
        font-weight: 600;
        color: var(--brand-strong);
      }

      input,
      select,
      textarea {
        width: 100%;
        border: 1px solid rgba(108, 153, 188, 0.38);
        background: rgba(255, 255, 255, 0.95);
        border-radius: 0.62rem;
        padding: 0.62rem 0.7rem;
        font: inherit;
        color: var(--ink);
      }

      textarea {
        min-height: 120px;
        resize: vertical;
      }

      .submit-row {
        margin-top: 0.8rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.7rem;
      }

      .form-status {
        margin-top: 0.75rem;
        padding: 0.6rem 0.7rem;
        border-radius: 0.62rem;
        font-size: 0.9rem;
      }

      .form-status.success {
        background: rgba(12, 117, 58, 0.12);
        border: 1px solid rgba(12, 117, 58, 0.28);
        color: #0b5f33;
      }

      .form-status.error {
        background: rgba(173, 38, 38, 0.12);
        border: 1px solid rgba(173, 38, 38, 0.28);
        color: #7d2121;
      }

      .hcaptcha-wrap {
        margin-top: 0.65rem;
      }

      .helper {
        margin: 0;
        font-size: 0.82rem;
        color: var(--ink-soft);
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.68rem 1rem;
        border-radius: 0.75rem;
        border: 1px solid transparent;
        font-weight: 600;
        font-family: "Sora", sans-serif;
        text-decoration: none;
        cursor: pointer;
      }

      .button .icon {
        width: 1rem;
        height: 1rem;
        margin-right: 0.35rem;
      }

      .button-primary {
        background: linear-gradient(125deg, #1f5a89, #2f709f);
        color: #edf6ff;
      }

      .site-footer {
        margin-top: 1.6rem;
      }

      @media (max-width: 920px) {
        .header-overlay {
          padding: 2rem 1.2rem 2rem 1.2rem;
          align-items: flex-start;
        }

        .header-overlay .hero-title {
          font-size: 2rem;
        }

        .header-overlay .hero-desc {
          font-size: 1rem;
        }

        .contact-layout {
          grid-template-columns: 1fr;
        }

        .form-grid {
          grid-template-columns: 1fr;
        }

        .submit-row {
          flex-direction: column;
          align-items: flex-start;
        }
      }
    </style>
  </Fragment>

  <SiteHeader active="contact" />
  <div class="header-hero">
    <img src="/contact-bg.png" alt="Contact Stone Dragon Media – start a project or ask about our services" />
    <div class="header-overlay">
      <span class="about-label">CONTACT</span>
      <span class="hero-title">Get in Touch</span>
      <span class="hero-desc">
        Ready to start your next project? Share your details and we will reach out to discuss your vision and guide you through the process.
      </span>
    </div>
  </div>

  <div class="page">
    <div class="contact-layout">
      <div class="form-card">
        <h1>Start a Conversation</h1>
        <p>Share a few project details and we will follow up quickly.</p>
        <form id="contact-form" method="post" action="https://api.web3forms.com/submit" novalidate>
          <input type="hidden" name="access_key" value="8b9f961f-4a2f-43bc-938a-11f26885cd31" />
          <div class="form-grid">
            <div class="field">
              <label for="name">Name</label>
              <input id="name" name="name" type="text" required />
            </div>
            <div class="field">
              <label for="email">Email</label>
              <input id="email" name="email" type="email" required />
            </div>
            <div class="field">
              <label for="company">Company</label>
              <input id="company" name="company" type="text" />
            </div>
            <div class="field">
              <label for="timeline">Timeline</label>
              <select id="timeline" name="timeline">
                <option>As soon as possible</option>
                <option>Within 30 days</option>
                <option>1-3 months</option>
                <option>Exploring options</option>
              </select>
            </div>
            <div class="field full">
              <label for="message">Project Details</label>
              <textarea id="message" name="message" placeholder="Tell us about your goals, scope, and desired outcomes." required></textarea>
            </div>
          </div>
          <div class="hcaptcha-wrap">
            <div class="h-captcha" data-sitekey="50b2fe65-b00b-4b9e-ad62-3ba471098be2"></div>
          </div>
          <div class="submit-row">
            <p class="helper">Share your details and we will follow up to discuss your project.</p>
            <button id="contact-submit" class="button button-primary" type="submit">
              <Icon class="icon" name="lucide:send" aria-hidden="true" />
              Send Inquiry
            </button>
          </div>
          <div id="contact-form-status" class="form-status" role="status" aria-live="polite" hidden></div>
        </form>
      </div>

      <div class="info-panel">
        <div class="info-item">
          <Icon class="info-icon" name="lucide:map-pin" aria-hidden="true" />
          <div>
            <h3>Based in Sandusky, OH</h3>
            <p>Local roots with remote delivery for clients across the country.</p>
          </div>
        </div>
        <div class="info-item">
          <Icon class="info-icon" name="lucide:clock" aria-hidden="true" />
          <div>
            <h3>Quick Response</h3>
            <p>We follow up on all inquiries within one business day.</p>
          </div>
        </div>
        <div class="info-item">
          <Icon class="info-icon" name="lucide:shield-check" aria-hidden="true" />
          <div>
            <h3>No Obligation</h3>
            <p>Consultations are free. No pressure, no commitments required.</p>
          </div>
        </div>
        <div class="info-item">
          <Icon class="info-icon" name="lucide:layers" aria-hidden="true" />
          <div>
            <h3>Full-Service</h3>
            <p>From strategy through launch and beyond, we handle the entire project lifecycle.</p>
          </div>
        </div>
      </div>
    </div>
    <SiteFooter />
  </div>

  <script src="https://js.hcaptcha.com/1/api.js" async defer></script>
  <script>
    const form = document.getElementById("contact-form") as HTMLFormElement | null;
    const submitButton = document.getElementById("contact-submit") as HTMLButtonElement | null;
    const statusMessage = document.getElementById("contact-form-status") as HTMLDivElement | null;
    const originalButtonHtml = submitButton?.innerHTML;

    const setStatus = (type: "success" | "error", message: string) => {
      if (!statusMessage) return;
      statusMessage.hidden = false;
      statusMessage.className = `form-status ${type}`;
      statusMessage.textContent = message;
    };

    if (!form || !submitButton || !statusMessage) {
      throw new Error("Contact form elements are missing.");
    }

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      submitButton.disabled = true;
      submitButton.textContent = "Sending...";
      statusMessage.hidden = true;

      try {
        const hcaptcha = (window as Window & { hcaptcha?: { getResponse: () => string; reset: () => void } }).hcaptcha;
        const captchaResponse = hcaptcha?.getResponse();
        if (!captchaResponse) {
          setStatus("error", "Please complete the CAPTCHA.");
          return;
        }

        const formData = new FormData(form);
        const payload = {
          access_key: formData.get("access_key"),
          name: formData.get("name"),
          email: formData.get("email"),
          company: formData.get("company"),
          timeline: formData.get("timeline"),
          message: formData.get("message"),
          "h-captcha-response": captchaResponse,
        };

        const response = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });

        if (!response.ok) {
          throw new Error(`HTTP ${response.status}`);
        }

        const result = await response.json();
        if (result.success) {
          setStatus("success", "Message sent successfully. We will get back to you soon.");
          form.reset();
          hcaptcha?.reset();
        } else {
          setStatus("error", result.message || "Failed to send message. Please try again.");
        }
      } catch (error: unknown) {
        const message = error instanceof Error ? error.message : "Unknown error";
        setStatus("error", `Error sending message: ${message}`);
      } finally {
        submitButton.disabled = false;
        submitButton.innerHTML = originalButtonHtml ?? "Send Inquiry";
      }
    });
  </script>
</BaseLayout>
