---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Privacy Policy | Stone Dragon Media"
  description="Read the Stone Dragon Media privacy policy to understand how we collect, use, and protect your personal information."
  canonical="https://stonedragonmedia.com/privacy-policy/"
  ogUrl="https://stonedragonmedia.com/privacy-policy/"
  robots="noindex, follow"
>
  <Fragment slot="head">
    <style>
      :root {
        --surface: rgba(243, 248, 253, 0.95);
      }

      .wrapper {
        max-width: 980px;
        margin: 0 auto;
        padding: 2rem clamp(1.1rem, 2.5vw, 2.4rem) 3rem;
      }

      .card {
        background: var(--surface);
        border: 1px solid var(--line);
        border-radius: 1rem;
        padding: 1.4rem;
        box-shadow: 0 16px 30px rgba(18, 45, 69, 0.12);
      }

      h1,
      h2 {
        font-family: "Sora", sans-serif;
        color: var(--brand-strong);
      }

      p,
      li {
        color: var(--ink-soft);
        line-height: 1.6;
      }

      a {
        color: var(--brand-strong);
      }
    </style>
  </Fragment>

  <div class="wrapper">
    <div class="card">
      <h1>Privacy Policy</h1>
      <p>
        Stone Dragon Media values your privacy. This page explains what information may be
        collected when you contact us and how we use it.
      </p>

      <h2>Information We Collect</h2>
      <ul>
        <li>Contact information you provide (name, email, phone, company details).</li>
        <li>Project-related information shared in forms or consultations.</li>
        <li>Basic analytics data used to improve website performance and usability.</li>
      </ul>

      <h2>How We Use Information</h2>
      <ul>
        <li>Responding to inquiries and project requests.</li>
        <li>Delivering services and communicating project updates.</li>
        <li>Improving our website and user experience.</li>
      </ul>

      <h2>Contact</h2>
      <p>
        If you have privacy questions, please use our
        <a href="/contact">contact form</a>.
      </p>
    </div>
  </div>
</BaseLayout>
