---
import { Icon } from "astro-icon/components";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const currentYear = new Date().getFullYear();
const codingStartYear = 1998;
const yearsExperience = currentYear - codingStartYear;
---

<BaseLayout
  title="Stone Dragon Media | Web Design Agency"
  description="Stone Dragon Media builds high-performance web solutions and conversion-focused digital experiences for ambitious brands."
  canonical="https://stonedragonmedia.com/"
  ogUrl="https://stonedragonmedia.com/"
  includeGenerator={true}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["Organization", "LocalBusiness"],
      "name": "Stone Dragon Media",
      "url": "https://stonedragonmedia.com",
      "logo": "https://stonedragonmedia.com/logo.png",
      "image": "https://stonedragonmedia.com/logo.png",
      "description": "Stone Dragon Media builds custom web solutions, application development, digital marketing, and consulting services for growing businesses.",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Sandusky",
        "addressRegion": "OH",
        "addressCountry": "US"
      },
      "areaServed": "US",
      "sameAs": []
    })} />
    <style>
      .page {
        max-width: 1280px;
        margin: 0 auto;
        padding: 1rem clamp(1.1rem, 2.5vw, 2.4rem) 4.5rem;
      }

      .site-nav {
        margin-right: 0.45rem;
      }

      .brand-logo {
        width: min(100%, 380px);
        height: auto;
        display: block;
        filter: contrast(1.15) brightness(1.07);
      }

      .header-hero {
        position: relative;
        width: 100vw;
        left: 50%;
        right: 50%;
        margin-left: -50vw;
        margin-right: -50vw;
        height: 520px;
        max-width: 100vw;
        border-radius: 0;
        overflow: hidden;
        box-shadow: none;
        margin-bottom: 1rem;
        background: #122238;
      }

      .header-hero img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        object-position: center 35%;
      }

      .header-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
        padding: 3.5rem 3.5rem 3.5rem 8vw;
        color: #fff;
        background: linear-gradient(90deg, rgba(18, 34, 56, 0.82) 0%, rgba(18, 34, 56, 0.32) 60%, rgba(18, 34, 56, 0) 100%);
        font-family: "Sora", sans-serif;
        pointer-events: none;
        box-sizing: border-box;
      }

      .header-overlay .about-label {
        font-size: 1.1rem;
        font-weight: 600;
        letter-spacing: 0.13em;
        margin-bottom: 0.7rem;
        opacity: 0.92;
        border-bottom: 3px solid #7fa6d9;
        display: inline-block;
        padding-bottom: 0.2rem;
        text-transform: uppercase;
      }

      .header-overlay .hero-title {
        font-size: 2.8rem;
        font-weight: 800;
        margin: 0 0 1.2rem;
        line-height: 1.1;
        text-shadow: 0 2px 16px rgba(0, 0, 0, 0.18);
      }

      .header-overlay .hero-desc {
        font-size: 1.25rem;
        font-weight: 400;
        max-width: 32rem;
        line-height: 1.5;
        text-shadow: 0 2px 16px rgba(0, 0, 0, 0.18);
      }

      .cta {
        margin-top: 2.2rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
        pointer-events: all;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.72rem 1.12rem;
        border-radius: 0.82rem;
        border: 1px solid transparent;
        font-weight: 600;
        text-decoration: none;
        font-family: "Sora", sans-serif;
        transition: transform 160ms ease, box-shadow 160ms ease, border-color 160ms ease;
      }

      .button .icon {
        width: 1rem;
        height: 1rem;
        margin-right: 0.45rem;
        flex-shrink: 0;
      }

      .button:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 18px rgba(14, 46, 73, 0.2);
      }

      .button-primary {
        background: linear-gradient(125deg, #1f5a89, #2f709f);
        color: #edf6ff;
      }

      .button-secondary {
        border-color: rgba(191, 224, 248, 0.45);
        color: #e6f2ff;
        background: rgba(17, 44, 68, 0.45);
      }

      .panel,
      .services article,
      .metric {
        border: 1px solid var(--line);
        background: var(--surface);
        box-shadow: 0 16px 30px rgba(18, 45, 69, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.5);
      }

      .panel {
        border-radius: 1rem;
        padding: 1.2rem;
        background: rgba(233, 241, 248, 0.9);
      }

      .panel p {
        color: var(--ink-soft);
      }

      .metric {
        border-radius: 0.8rem;
        padding: 0.95rem;
      }

      .metric .icon {
        width: 1rem;
        height: 1rem;
        color: var(--brand);
        margin-bottom: 0.35rem;
      }

      .metric strong {
        display: block;
        font-size: 1.2rem;
        color: var(--brand-strong);
      }

      .metric span {
        font-size: 0.93rem;
        color: var(--ink-soft);
      }

      section {
        margin-top: 1.1rem;
      }

      section:first-child {
        margin-top: 0;
      }

      .site-footer {
        margin-top: 2.2rem;
        padding-top: 1.25rem;
      }

      .services {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
      }

      .services article {
        padding: 1rem;
        border-radius: 0.9rem;
      }

      .service-title {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .service-title .icon {
        width: 1.05rem;
        height: 1.05rem;
        color: var(--brand);
        flex-shrink: 0;
      }

      h2 {
        margin: 0 0 1rem;
        font-size: clamp(1.4rem, 2vw, 1.8rem);
        font-family: "Sora", sans-serif;
        color: var(--brand-strong);
      }

      h3 {
        margin: 0 0 0.45rem;
        font-size: 1.04rem;
        color: var(--brand-strong);
      }

      .services p {
        margin: 0;
        color: var(--ink-soft);
        font-size: 0.96rem;
      }

      @keyframes rise {
        from {
          opacity: 0;
          transform: translateY(14px);
        }

        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @media (max-width: 920px) {
        .site-nav {
          margin-right: 0;
        }

        .services {
          grid-template-columns: 1fr;
        }

        .header-hero {
          height: clamp(470px, 86vw, 640px);
        }

        .header-overlay {
          padding: 2rem 1.2rem;
          align-items: flex-start;
        }

        .header-overlay .hero-title {
          font-size: 2rem;
        }

        .header-overlay .hero-desc {
          font-size: 1rem;
        }

        .site-footer {
          padding-top: 1.2rem;
        }
      }
    </style>
  </Fragment>

  <SiteHeader active="home" showCta={true} />

  <div class="header-hero">
    <img src="/header-bg.png" alt="Stone Dragon Media – custom web design and digital strategy agency based in Sandusky, Ohio" />
    <div class="header-overlay">
      <span class="about-label">DIGITAL STRATEGY &amp; SOLUTIONS</span>
      <h1 class="hero-title">Premium web solutions for growing brands</h1>
      <span class="hero-desc">
        Stone Dragon Media delivers custom web solutions, application development, reliable hosting,
        and practical consulting to help businesses scale online.
        Backed by {yearsExperience} years of IT and development experience.
      </span>
      <div class="cta">
        <a class="button button-primary" href="/contact">
          <Icon class="icon" name="lucide:calendar-check-2" aria-hidden="true" />
          Book Discovery Call
        </a>
        <a class="button button-secondary" href="/services">
          <Icon class="icon" name="lucide:sparkles" aria-hidden="true" />
          View Services
        </a>
      </div>
    </div>
  </div>

  <div class="page">
    <section id="services">
      <h2>What We Do</h2>
      <div class="services">
        <article>
          <div class="service-title">
            <Icon class="icon" name="lucide:layout-template" aria-hidden="true" />
            <h3>Custom Web Solutions</h3>
          </div>
          <p>
            eCommerce sites, informational websites, landing pages, and custom business solutions built fast and built to last.
          </p>
        </article>
        <article>
          <div class="service-title">
            <Icon class="icon" name="lucide:cpu" aria-hidden="true" />
            <h3>Custom Application Development</h3>
          </div>
          <p>
            Internal tools, customer portals, workflow automation, and API integrations tailored to your operations.
          </p>
        </article>
        <article>
          <div class="service-title">
            <Icon class="icon" name="lucide:megaphone" aria-hidden="true" />
            <h3>Marketing</h3>
          </div>
          <p>
            SEO, PPC, social media, email, and content strategies that drive qualified traffic and measurable growth.
          </p>
        </article>
        <article>
          <div class="service-title">
            <Icon class="icon" name="lucide:bar-chart-2" aria-hidden="true" />
            <h3>Analytics &amp; Reporting</h3>
          </div>
          <p>
            GA4 setup, conversion tracking, custom dashboards, and performance audits to turn data into decisions.
          </p>
        </article>
        <article>
          <div class="service-title">
            <Icon class="icon" name="lucide:server" aria-hidden="true" />
            <h3>Hosting &amp; Infrastructure</h3>
          </div>
          <p>
            Domain management, cloud and VPS server setup, SSL, performance optimization, and backup planning.
          </p>
        </article>
        <article>
          <div class="service-title">
            <Icon class="icon" name="lucide:shield" aria-hidden="true" />
            <h3>Security &amp; Maintenance</h3>
          </div>
          <p>
            Ongoing site care including security hardening, updates, uptime monitoring, and vulnerability assessments.
          </p>
        </article>
        <article>
          <div class="service-title">
            <Icon class="icon" name="lucide:palette" aria-hidden="true" />
            <h3>Branding &amp; Design</h3>
          </div>
          <p>
            Logo design, brand style guides, color and typography systems, and print and digital asset creation.
          </p>
        </article>
        <article>
          <div class="service-title">
            <Icon class="icon" name="lucide:compass" aria-hidden="true" />
            <h3>Consulting &amp; Strategy</h3>
          </div>
          <p>
            Technology selection, digital transformation planning, data migration, and project roadmapping.
          </p>
        </article>
      </div>
    </section>

    <SiteFooter />
  </div>
</BaseLayout>
