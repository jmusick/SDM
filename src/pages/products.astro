---
import { Icon } from "astro-icon/components";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Products | Stone Dragon Media"
  description="Explore products by Stone Dragon Media, including Tagsta.sh - a modern bookmarking and resource organization tool built for productivity."
  canonical="https://stonedragonmedia.com/products/"
  ogUrl="https://stonedragonmedia.com/products/"
>
  <Fragment slot="head">
    <style>
      .page {
        max-width: 1280px;
        margin: 0 auto;
        padding: 1rem clamp(1.1rem, 2.5vw, 2.4rem) 4rem;
      }

      .header-hero {
        position: relative;
        width: 100vw;
        left: 50%;
        right: 50%;
        margin-left: -50vw;
        margin-right: -50vw;
        height: 520px;
        max-width: 100vw;
        border-radius: 0;
        overflow: hidden;
        box-shadow: none;
        margin-bottom: 1rem;
        background: #122238;
      }

      .header-hero img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        object-position: center 70%;
      }

      .header-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: flex-start;
        padding: 3.5rem 3.5rem 3.5rem 8vw;
        color: #fff;
        background: linear-gradient(90deg, rgba(18, 34, 56, 0.82) 0%, rgba(18, 34, 56, 0.32) 60%, rgba(18, 34, 56, 0) 100%);
        font-family: "Sora", sans-serif;
        pointer-events: none;
        box-sizing: border-box;
      }

      .header-overlay .about-label {
        font-size: 1.1rem;
        font-weight: 600;
        letter-spacing: 0.13em;
        margin-bottom: 0.7rem;
        opacity: 0.92;
        border-bottom: 3px solid #7fa6d9;
        display: inline-block;
        padding-bottom: 0.2rem;
      }

      .header-overlay .hero-title {
        font-size: 2.8rem;
        font-weight: 800;
        margin-bottom: 1.2rem;
        line-height: 1.1;
        text-shadow: 0 2px 16px rgba(0, 0, 0, 0.18);
      }

      .header-overlay .hero-desc {
        font-size: 1.25rem;
        font-weight: 400;
        max-width: 32rem;
        line-height: 1.5;
        text-shadow: 0 2px 16px rgba(0, 0, 0, 0.18);
      }

      h1 {
        font-family: "Sora", sans-serif;
        color: var(--brand-strong);
        margin: 0 0 1rem;
      }

      .lead {
        color: var(--ink-soft);
        max-width: 70ch;
      }

      .product {
        margin-top: 1.2rem;
        border: 1px solid var(--line);
        background: var(--surface);
        border-radius: 1rem;
        padding: 1.2rem;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background: rgba(239, 247, 253, 0.9);
        color: var(--brand-strong);
        border: 1px solid var(--line);
        border-radius: 999px;
        font-size: 0.82rem;
        font-weight: 600;
        padding: 0.35rem 0.65rem;
      }

      .badge .icon {
        width: 0.92rem;
        height: 0.92rem;
      }

      h2 {
        margin: 0.85rem 0 0.45rem;
        color: var(--brand-strong);
        font-family: "Sora", sans-serif;
      }

      .product p {
        color: var(--ink-soft);
        line-height: 1.6;
        margin: 0;
      }

      .actions {
        margin-top: 1rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.7rem;
      }

      .button {
        display: inline-flex;
        align-items: center;
        text-decoration: none;
        font-family: "Sora", sans-serif;
        padding: 0.65rem 1rem;
        border-radius: 0.75rem;
        font-weight: 600;
        border: 1px solid transparent;
      }

      .button .icon {
        width: 1rem;
        height: 1rem;
        margin-right: 0.4rem;
      }

      .button-primary {
        color: #edf6ff;
        background: linear-gradient(125deg, #1f5a89, #2f709f);
      }

      .button-secondary {
        color: var(--brand-strong);
        background: rgba(239, 247, 253, 0.86);
        border-color: rgba(43, 90, 124, 0.4);
      }

      .site-footer {
        margin-top: 2rem;
      }

      @media (max-width: 920px) {
        .header-overlay {
          padding: 2rem 1.2rem 2rem 1.2rem;
          align-items: flex-start;
        }

        .header-overlay .hero-title {
          font-size: 2rem;
        }

        .header-overlay .hero-desc {
          font-size: 1rem;
        }
      }
    </style>
  </Fragment>

  <SiteHeader active="products" />

  <div class="header-hero">
    <img src="/products-header.png" alt="Stone Dragon Media products – practical tools for productivity and workflow" />
    <div class="header-overlay">
      <span class="about-label">PRODUCTS</span>
      <span class="hero-title">Our Products</span>
      <span class="hero-desc">
        Practical tools designed to solve real workflow problems and boost productivity.
      </span>
    </div>
  </div>

  <div class="page">
    <h1>Products</h1>
    <p class="lead">Stone Dragon Media builds practical products that solve real workflow problems.</p>
    <section class="product" aria-label="Featured product">
      <div class="badge">
        <Icon class="icon" name="lucide:star" aria-hidden="true" />
        Featured Product
      </div>
      <h2>Tagsta.sh</h2>
      <p>
        Tagsta.sh is a modern bookmarking and reference organization tool designed to make it easy
        to capture, tag, and retrieve important links and resources fast.
      </p>
      <div class="actions">
        <a class="button button-primary" href="https://tagsta.sh/" target="_blank" rel="noreferrer noopener">
          <Icon class="icon" name="lucide:external-link" aria-hidden="true" />
          Visit Tagsta.sh
        </a>
        <a class="button button-secondary" href="/contact">
          <Icon class="icon" name="lucide:messages-square" aria-hidden="true" />
          Ask About Product Development
        </a>
      </div>
    </section>
    <SiteFooter />
  </div>
</BaseLayout>
