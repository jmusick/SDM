{
  "version": "0.2.0",
  "configurations": [
    {
      "command": "npm run dev -- --host --port 4321",
      "name": "Stone Dragon Media - Dev Server",
      "request": "launch",
      "type": "node-terminal",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "(https?://(?:localhost|ark-prime):4321)",
        "uriFormat": "http://ark-prime:4321"
      }
    }
  ]
}
